# ── GitHub ────────────────────────────────────────────────────
# GitHub Personal Access Token (GitHub Models API + Copilot)
GITHUB_TOKEN=ghp_your_token_here

# ── AI API Keys ───────────────────────────────────────────────
# Grok (xAI)
GROK_API_KEY=xai-your_key_here

# DeepSeek
DEEPSEEK_API_KEY=sk-your_key_here

# Google Gemini
GEMINI_API_KEY=your_key_here

# ── Flask / Control Bridge ────────────────────────────────────
FLASK_DEBUG=0
# FLASK_SECRET_KEY=change_me_in_production

# ── Bundler / SandFS ──────────────────────────────────────────
SANDFS_ROOT=src/bundler/sandfs
SNAPSHOT_DIR=src/bundler/snapshots
MAX_AUTO_SNAPSHOTS=10
ALLOWED_ID_TAGS=GROK,DV,GEM,IGOR,LIPPY,ME

# ── Vite / React (react-cloudflare-app) ───────────────────────
# VITE_WORKER_URL=http://localhost:8787
